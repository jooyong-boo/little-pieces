{
  "name": "@little-pieces/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "build:railway": "pnpm prisma:generate && pnpm build",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "start:railway": "pnpm start:prod",
    "postinstall": "prisma generate",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@little-pieces/shared": "workspace:*",
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.16",
    "@prisma/client": "^6.19.2",
    "argon2": "^0.44.0",
    "dotenv": "^17.2.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@little-pieces/eslint-config": "workspace:*",
    "@little-pieces/typescript-config": "workspace:*",
    "@types/node": "^25.3.5",
    "@types/passport-jwt": "^4.0.1",
    "eslint": "^9.0.0",
    "prisma": "^6.19.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
